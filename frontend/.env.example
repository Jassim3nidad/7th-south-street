# Next.js Application Environment Variables
# For local development, these values should point to your local Supabase instance.
# Run `npx supabase status` to retrieve your local keys.

# Browser-safe variables
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your.local.anon.key.from.supabase.status
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only variables (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your.local.service_role.key.from.supabase.status
NEWSLETTER_RATE_LIMIT_SALT=a-long-random-local-salt
